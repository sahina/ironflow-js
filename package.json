{
  "name": "@ironflow/js-sdk-mirror",
  "private": true,
  "version": "0.0.0",
  "description": "Public source mirror for Ironflow JS SDK packages (@ironflow/core, @ironflow/browser, @ironflow/node, @ironflow/langgraph)",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "2.2.3",
    "@types/node": "^22.19.18",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
