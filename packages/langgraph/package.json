{
  "name": "@ironflow/langgraph",
  "version": "0.22.5-mirror.7",
  "description": "LangGraph checkpoint saver backed by Ironflow entity streams — durable agent state with crash-resume",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "test": "pnpm typecheck && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ironflow/core": "workspace:^",
    "@ironflow/node": "workspace:^"
  },
  "peerDependencies": {
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph-checkpoint": "^1.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint": "^1.0.2",
    "@types/node": "^22.19.18",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ironflow",
    "langgraph",
    "checkpoint",
    "saver",
    "durable",
    "agent"
  ],
  "author": "Ironflow",
  "license": "LicenseRef-Ironflow-EULA",
  "homepage": "https://ironflow.run",
  "bugs": {
    "url": "https://github.com/sahina/ironflow-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sahina/ironflow-js.git",
    "directory": "packages/langgraph"
  },
  "publishConfig": {
    "access": "public"
  }
}
