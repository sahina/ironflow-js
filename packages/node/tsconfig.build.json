{
  // Emit config used by `pnpm build` and `pnpm dev` (watch mode).
  //
  // EXCLUDES test files and __type_tests__ on purpose so dist/ stays
  // production-only. Test type rot is gated separately by:
  //   1. Editor TS server reading tsconfig.json (live diagnostics)
  //   2. `pnpm test` running `pnpm typecheck` (CI-authoritative)
  //
  // `pnpm dev --watch` is for emit, not test typecheck.
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@ironflow/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "src/**/__type_tests__/**",
    "tests/**"
  ],
  "references": [{ "path": "../core/tsconfig.build.json" }]
}
